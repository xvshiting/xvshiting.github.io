[{% for post in site.posts %}{"title":{{ post.title | jsonify }},"url":{{ post.url | jsonify }},"date":{{ post.date | date_to_string | jsonify }},"tags":{{ post.tag | join: ',' | jsonify }},"excerpt":{{ post.excerpt | strip_html | truncate: 120 | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}]